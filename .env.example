# nanoaios 配置
# 优先级：环境变量 > config.toml > 默认值

# ---- 基础配置 ----
NANOAIOS_NODE_NAME=nanoaios-local
NANOAIOS_API_HOST=0.0.0.0
NANOAIOS_API_PORT=4242

# ---- Provider 配置 ----
# 可选值：mock, openai_compatible
NANOAIOS_PROVIDER_KIND=mock
NANOAIOS_PROVIDER_MODEL=nanoaios/mock-v1
NANOAIOS_PROVIDER_BASE_URL=https://api.openai.com/v1

# ---- API Key ----
# 当 PROVIDER_KIND=openai_compatible 时需要设置
OPENAI_API_KEY=sk-your-api-key-here
